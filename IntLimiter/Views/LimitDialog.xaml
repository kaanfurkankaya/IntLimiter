<Window x:Class="IntLimiter.Views.LimitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hız Limiti Ayarla"
        Width="460" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF1C1C1C"
        Foreground="White"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Padding="28" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Hız Limiti Ayarla" FontSize="20" FontWeight="SemiBold" Foreground="White" />
                <TextBlock x:Name="ProcessNameText" FontSize="13" Foreground="#FF9D9D9D" Margin="0,6,0,0" />
            </StackPanel>

            <!-- Download Limit -->
            <Border Grid.Row="2" Background="#FF2D2D2D" CornerRadius="8" Padding="14,12"
                    BorderBrush="#FF454545" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="↓ İndirme" Foreground="#FF60CDFF"
                               FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                    <TextBox x:Name="DownloadLimitBox" Grid.Column="1"
                             Background="#FF383838" Foreground="White"
                             BorderBrush="#FF505050" BorderThickness="1"
                             Padding="10,7" Margin="12,0" FontSize="14"
                             HorizontalAlignment="Stretch" TextAlignment="Right"
                             CaretBrush="White" Text="0" />
                    <ComboBox x:Name="DownloadUnitCombo" Grid.Column="2"
                              Style="{StaticResource Win11ComboBox}"
                              Width="100" SelectedIndex="1">
                        <ComboBoxItem Content="Kbit/s" />
                        <ComboBoxItem Content="Mbit/s" />
                        <ComboBoxItem Content="KB/s" />
                        <ComboBoxItem Content="MB/s" />
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Upload Limit -->
            <Border Grid.Row="4" Background="#FF2D2D2D" CornerRadius="8" Padding="14,12"
                    BorderBrush="#FF454545" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="↑ Yükleme" Foreground="#FF6CCB5F"
                               FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                    <TextBox x:Name="UploadLimitBox" Grid.Column="1"
                             Background="#FF383838" Foreground="White"
                             BorderBrush="#FF505050" BorderThickness="1"
                             Padding="10,7" Margin="12,0" FontSize="14"
                             HorizontalAlignment="Stretch" TextAlignment="Right"
                             CaretBrush="White" Text="0" />
                    <ComboBox x:Name="UploadUnitCombo" Grid.Column="2"
                              Style="{StaticResource Win11ComboBox}"
                              Width="100" SelectedIndex="1">
                        <ComboBoxItem Content="Kbit/s" />
                        <ComboBoxItem Content="Mbit/s" />
                        <ComboBoxItem Content="KB/s" />
                        <ComboBoxItem Content="MB/s" />
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Info -->
            <TextBlock Grid.Row="5" Foreground="#FF717171" FontSize="11"
                       VerticalAlignment="Top" Margin="0,10,0,0" TextWrapping="Wrap"
                       Text="0 girilirse sınırlama kaldırılır." />

            <!-- Buttons -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="İptal" Style="{StaticResource Win11Button}"
                        Width="100" Padding="0,9" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="Uygula" Style="{StaticResource Win11AccentButton}"
                        Width="100" Padding="0,9" Click="Apply_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
