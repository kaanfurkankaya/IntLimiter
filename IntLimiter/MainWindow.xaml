<Window x:Class="IntLimiter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:IntLimiter.Converters"
        Title="IntLimiter"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="500"
        Background="#FF1C1C1C"
        Foreground="White"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <conv:BytesToHumanReadableConverter x:Key="BytesConverter" />
        <conv:BitsToDisplayConverter x:Key="BitsConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left Sidebar -->
            <ColumnDefinition Width="220" />
            <!-- Main Content -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT SIDEBAR (Win11 Task Manager Style) ═══ -->
        <Border Grid.Column="0" Background="#FF252525"
                BorderBrush="{StaticResource WinBorderSubtleBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App Title -->
                <StackPanel Grid.Row="0" Margin="18,18,18,16">
                    <TextBlock Text="IntLimiter" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="Ağ Yöneticisi" FontSize="11" Foreground="{StaticResource WinTextTertiaryBrush}" Margin="0,2,0,0" />
                </StackPanel>

                <!-- Navigation (single item for now, expandable) -->
                <StackPanel Grid.Row="1" Margin="4,0">
                    <RadioButton Style="{StaticResource SidebarButton}" IsChecked="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📡" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="İşlemler" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Speed Summary Cards -->
                <StackPanel Grid.Row="2" VerticalAlignment="Top" Margin="14,20,14,0">
                    <!-- Download Card -->
                    <Border Background="#0F60CDFF" CornerRadius="8" Padding="14,12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="İndirme" FontSize="11" Foreground="{StaticResource WinTextSecondaryBrush}" />
                            <TextBlock Text="{Binding TotalDownloadSpeed, Converter={StaticResource BytesConverter}}"
                                       FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource DownloadBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Upload Card -->
                    <Border Background="#0F6CCB5F" CornerRadius="8" Padding="14,12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Yükleme" FontSize="11" Foreground="{StaticResource WinTextSecondaryBrush}" />
                            <TextBlock Text="{Binding TotalUploadSpeed, Converter={StaticResource BytesConverter}}"
                                       FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource UploadBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Active Processes -->
                    <Border Background="#0FFFFFFF" CornerRadius="8" Padding="14,12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Aktif İşlemler" FontSize="11" Foreground="{StaticResource WinTextSecondaryBrush}" />
                            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,4,0,0">
                                <Run Text="{Binding ActiveProcessCount, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Global Limit -->
                    <Border Background="#120078D4" CornerRadius="8" Padding="14,10" Margin="0,8,0,0">
                        <StackPanel>
                            <Button Style="{StaticResource Win11AccentButton}" Padding="10,6"
                                    Command="{Binding SetGlobalLimitCommand}" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="🌐" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="PC Limiti Ayarla" FontSize="12" VerticalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </Button>

                            <!-- Active global limit -->
                            <StackPanel Visibility="{Binding IsGlobalLimitActive, Converter={StaticResource BoolToVisConverter}}"
                                        Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Aktif:" FontSize="11" Foreground="{StaticResource WinTextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding GlobalLimitText}" FontSize="12"
                                               Foreground="{StaticResource WinWarningBrush}" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Content="Limiti Kaldır" Style="{StaticResource Win11Button}"
                                        Command="{Binding RemoveGlobalLimitCommand}"
                                        Padding="8,4" FontSize="11" Margin="0,6,0,0"
                                        HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Version -->
                <TextBlock Grid.Row="3" Text="v1.2 · Yönetici" FontSize="10"
                           Foreground="{StaticResource WinTextTertiaryBrush}"
                           Margin="18,0,0,12" />
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Padding="16,10" Background="{StaticResource WinBgSolidBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="320" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox x:Name="SearchBox" Style="{StaticResource Win11TextBox}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="🔍  İşlem ara..." IsHitTestVisible="False"
                                   Foreground="{StaticResource WinTextTertiaryBrush}"
                                   VerticalAlignment="Center" Margin="14,0,0,0" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox Content="Sadece aktif" Style="{StaticResource Win11CheckBox}"
                                  IsChecked="{Binding ShowOnlyActive}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DataGrid -->
            <DataGrid Grid.Row="1"
                      Style="{StaticResource Win11DataGrid}"
                      ColumnHeaderStyle="{StaticResource Win11ColumnHeader}"
                      RowStyle="{StaticResource Win11DataGridRow}"
                      CellStyle="{StaticResource Win11DataGridCell}"
                      ItemsSource="{Binding Processes}"
                      SelectedItem="{Binding SelectedProcess}"
                      Background="{StaticResource WinBgSolidBrush}">

                <DataGrid.ContextMenu>
                    <ContextMenu Style="{StaticResource Win11ContextMenu}">
                        <MenuItem Header="⚙  Hız Limiti Ayarla" Style="{StaticResource Win11MenuItem}"
                                  Command="{Binding SetLimitCommand}" />
                        <MenuItem Header="🔓  Limiti Kaldır" Style="{StaticResource Win11MenuItem}"
                                  Command="{Binding RemoveLimitCommand}" />
                        <Separator Background="{StaticResource WinBorderSubtleBrush}" Margin="8,4" />
                        <MenuItem Header="📁  Dosya Konumunu Aç" Style="{StaticResource Win11MenuItem}"
                                  Command="{Binding OpenFileLocationCommand}" />
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>
                    <!-- Process Name -->
                    <DataGridTemplateColumn Header="İşlem" Width="*" MinWidth="180" SortMemberPath="ProcessName">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}" Width="18" Height="18" Margin="0,0,10,0"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <TextBlock Text="●" Margin="0,0,6,0" VerticalAlignment="Center" FontSize="7">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource WinSuccessBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLimited}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource WinWarningBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ProcessName}" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="PID" Width="60" Binding="{Binding ProcessId}" />

                    <DataGridTemplateColumn Header="↓ İndirme" Width="105" SortMemberPath="DownloadSpeed">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DownloadSpeed, Converter={StaticResource BytesConverter}}"
                                           Foreground="{StaticResource DownloadBrush}" FontSize="13" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="↑ Yükleme" Width="105" SortMemberPath="UploadSpeed">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding UploadSpeed, Converter={StaticResource BytesConverter}}"
                                           Foreground="{StaticResource UploadBrush}" FontSize="13" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Toplam ↓" Width="85" SortMemberPath="TotalDownloaded">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TotalDownloaded, Converter={StaticResource BytesConverter}, ConverterParameter=total}"
                                           Foreground="{StaticResource WinTextSecondaryBrush}" FontSize="12" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Toplam ↑" Width="85" SortMemberPath="TotalUploaded">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TotalUploaded, Converter={StaticResource BytesConverter}, ConverterParameter=total}"
                                           Foreground="{StaticResource WinTextSecondaryBrush}" FontSize="12" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Limit ↓" Width="95" SortMemberPath="DownloadLimit">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DownloadLimit, Converter={StaticResource BitsConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource WinTextTertiaryBrush}" />
                                            <Setter Property="FontSize" Value="12" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLimited}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource WinWarningBrush}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Limit ↑" Width="95" SortMemberPath="UploadLimit">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding UploadLimit, Converter={StaticResource BitsConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource WinTextTertiaryBrush}" />
                                            <Setter Property="FontSize" Value="12" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLimited}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource WinWarningBrush}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
