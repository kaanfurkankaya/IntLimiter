<Page x:ConnectionId='1'
    x:Class="IntLimiter.App.Pages.LimitsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="Limits &amp; Rules" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="Configure global and per-process network traffic limits." Style="{ThemeResource BodyTextBlockStyle}" />
            <Button x:ConnectionId='2' Content="Add Mock Rule" Style="{ThemeResource AccentButtonStyle}"                                                />
            
            <ListView x:ConnectionId='3'                                                    >
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" Margin="0,4" CornerRadius="4">
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Width="150" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding DownloadLimitBytesPerSecond}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding UploadLimitBytesPerSecond}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>

