<Page x:ConnectionId='1'
    x:Class="IntLimiter.App.Pages.ProcessesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Spacing="16" Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Processes" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock x:ConnectionId='5'                                                         TextWrapping="Wrap" />
            <AutoSuggestBox x:ConnectionId='6' PlaceholderText="Search processes..."                                                   Width="300" HorizontalAlignment="Left" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock x:ConnectionId='2' Grid.Row="0"                                                          TextWrapping="Wrap" Margin="0,0,0,12" />

            <ListView x:ConnectionId='3' Grid.Row="1"                                                        >
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="12" Margin="0,0,0,8" CornerRadius="6">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding ProcessName}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding DisplayIdentity}" Opacity="0.7" />
                                    <TextBlock Text="{Binding ExecutablePath}" Opacity="0.6" TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Download" Opacity="0.7" />
                                    <TextBlock Text="{Binding DisplayDownloadRate}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Upload" Opacity="0.7" />
                                    <TextBlock Text="{Binding DisplayUploadRate}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>

