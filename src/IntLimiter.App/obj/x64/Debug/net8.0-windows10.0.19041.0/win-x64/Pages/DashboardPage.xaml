<Page x:ConnectionId='1'
    x:Class="IntLimiter.App.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="Dashboard" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock x:ConnectionId='2'                                                         TextWrapping="Wrap" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Global Network Usage" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Download" />
                    <TextBlock x:ConnectionId='3'                                                      />
                    <TextBlock Text="Upload" />
                    <TextBlock x:ConnectionId='4'                                                    />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>

