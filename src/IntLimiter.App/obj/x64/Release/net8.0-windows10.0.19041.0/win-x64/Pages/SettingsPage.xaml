<Page x:ConnectionId='1'
    x:Class="IntLimiter.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />
            <ToggleSwitch Header="Dark Mode" OffContent="Light" OnContent="Dark" />
            <ComboBox Header="Display Units">
                <ComboBoxItem Content="MB/s" IsSelected="True" />
                <ComboBoxItem Content="KB/s" />
                <ComboBoxItem Content="Mbit/s" />
                <ComboBoxItem Content="Kbit/s" />
            </ComboBox>
            <TextBlock x:ConnectionId='2'                                                       Margin="0,24,0,0"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:ConnectionId='3'                                                                                                         />
                <Button x:ConnectionId='4' Content="Install &amp; Restart"                                                                                                                                  Style="{ThemeResource AccentButtonStyle}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>

