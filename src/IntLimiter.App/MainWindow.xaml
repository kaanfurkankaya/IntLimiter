<Window
    x:Class="IntLimiter.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="IntLimiter">

    <Grid>
        <NavigationView x:Name="NavView" PaneDisplayMode="Left" SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Home" Content="Dashboard" Tag="DashboardPage"/>
                <NavigationViewItem Icon="List" Content="Processes" Tag="ProcessesPage"/>
                <NavigationViewItem Icon="Help" Content="Limits" Tag="LimitsPage"/>
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
