<Page
    x:Class="IntLimiter.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />
            <ToggleSwitch Header="Dark Mode" OffContent="Light" OnContent="Dark" />
            <ComboBox Header="Display Units">
                <ComboBoxItem Content="MB/s" IsSelected="True" />
                <ComboBoxItem Content="KB/s" />
                <ComboBoxItem Content="Mbit/s" />
                <ComboBoxItem Content="Kbit/s" />
            </ComboBox>
            <TextBlock Text="{x:Bind ViewModel.CurrentVersion, Mode=OneWay}" Margin="0,24,0,0"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}" Command="{x:Bind ViewModel.CheckUpdatesCommand}" />
                <Button Content="Install &amp; Restart" Visibility="{x:Bind ViewModel.IsUpdateAvailable, Mode=OneWay}" Command="{x:Bind ViewModel.ApplyUpdateCommand}" Style="{ThemeResource AccentButtonStyle}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
